from hugr import HugrClient


client = HugrClient()
print("URL:", client._url)
print("Auth:", "api_key" if client._api_key else "token" if client._token else "public")


client2 = HugrClient.from_connection("local-oidc")
print("Named connection URL:", client2._url)


import os
client3 = HugrClient(url=os.environ.get("HUGR_URL", "http://localhost:15004/ipc"))
print("Explicit URL:", client3._url)


client4 = HugrClient(
    url="http://localhost:15004/ipc",
    api_key="test-key",
    api_key_header="X-Custom-Api-Key",
)
print("API key header:", client4._api_key_header)
assert client4._api_key_header == "X-Custom-Api-Key"


result = client.query("""
{
    core {
        data_sources {
            name
        }
    }
}
""")


result


df = result.df("data.core.data_sources")
print(type(df))  # pandas.DataFrame
print(df.head())


table = result.parts["data.core.data_sources"].to_arrow()
print(type(table))  # pyarrow.Table
print(table.schema)
print(f"Rows: {table.num_rows}")


result.parts["data.core.data_sources"]


geo_result = client.query("""
{
    osm {
        de {
            osm_amenities(limit: 50000) {
                name
                category
                geom
            }
        }
    }
    core {
        data_sources @stats{
            name
        }
    }
}
""")


geo_result


geo_result


h3d = client.query("""
query deOSMByH3 {
  h3(resolution: 6) @stats{
    cell
    resolution
    data{
      lk: osm_bw_osm_administrative_boundaries_aggregation(
        field: "geom"
        filter:{admin_level: {eq:6}},
        divide_values:false
        inner: true
      ){
        pop: _join(fields: ["de_code"]) {
          zensus_population(fields: ["db_RS"]){
            EWZ{
              sum
            }
          }
        }
      }
      houses: osm_bw_osm_buildings_aggregation(
        field: "geom"
        filter: {building_class: {eq:"residential"}}
      ){
        _rows_count
        area_sqm{
          sum
        }
      }
    }
    pop: distribution_by(
      numerator: "data.lk.pop.zensus_population.EWZ.sum"
      denominator: "data.houses.area_sqm.sum"
    ){
      value
      ratio
      numerator
      denominator
      denominator_total
    }
  }
}
""")


h3d



